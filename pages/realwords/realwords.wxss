.container {
  min-height: 100vh;
  background-color: #FDFBF7;
  padding: 20rpx;
}

.header {
  padding: 30rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #B91C1C;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.words-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

.word-item {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 10rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.word-text {
  font-size: 36rpx;
  color: #2C3E50;
  font-weight: 500;
}

/* 结果弹窗样式 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 95vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-word {
  font-size: 44rpx;
  font-weight: bold;
  color: #B91C1C;
}

.modal-close {
  font-size: 50rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  height: 65vh;
  box-sizing: border-box;
}

.result-pinyin {
  margin-bottom: 20rpx;
}

.pinyin-text {
  font-size: 28rpx;
  color: #666;
}

.definition-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
}

.definition-label-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 15rpx;
}

.definition-label {
  font-size: 24rpx;
  color: #B91C1C;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.definition-meaning {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.source-text {
  margin-top: 15rpx;
  font-size: 26rpx;
  color: #666;
}

.source-label {
  color: #999;
}

.usage-category {
  margin-top: 15rpx;
}

.category-text {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: #FFF3E0;
  color: #E65100;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.examples-section {
  margin-top: 20rpx;
}

.examples-label {
  font-size: 26rpx;
  color: #B91C1C;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.example-item {
  padding: 15rpx;
  background-color: #fff;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.example-sentence {
  font-size: 28rpx;
  color: #333;
  display: block;
  font-style: italic;
}

.example-translation {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.etymology-section {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

.etymology-label {
  font-size: 28rpx;
  color: #B91C1C;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.etymology-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
  word-wrap: break-word;
}

.modal-footer {
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.collect-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background-color: #B91C1C;
  border-radius: 50rpx;
}

.collect-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.collect-text {
  color: #fff;
  font-size: 30rpx;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.loading-box {
  background-color: #fff;
  padding: 40rpx 60rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #B91C1C;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #666;
  font-size: 28rpx;
}