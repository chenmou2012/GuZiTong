<!-- pages/learn/learn.wxml -->
<view class="container" style="padding-top: calc(48rpx + {{statusBarHeight}}px)">
  <!-- BEGIN: MainHeader -->
  <header wx:if="{{!learning}}" class="main-header">
    <h1 class="header-title">文言文学习</h1>
  </header>
  <!-- END: MainHeader -->

  <!-- BEGIN: ContentArea -->
  <main wx:if="{{!learning}}" class="content-area">
    <!-- BEGIN: ProgressCard -->
    <section class="progress-card">
      <view class="progress-card-inner">
        <view class="progress-card-left">
          <view class="progress-card-status-area">
            <text class="progress-card-status">正在学习</text>
          </view>
          <view class="progress-card-title-area">
            <text class="progress-card-title">《初中文言文字词》</text>
          </view>
          <view class="progress-card-info-area">
            <text class="progress-card-current">当前章节 <text class="divider">|</text> <text class="current-word">{{currentLearningWord}}</text></text>
            <text class="progress-card-chapter">本章进度 <text class="divider">|</text> <text class="chapter-count">{{learnedCount}} / {{totalCount}} 词</text></text>
          </view>
        </view>
        <!-- Progress Indicator -->
        <view class="progress-card-right">
          <view class="progress-ring-container">
            <view class="progress-ring-bg"></view>
            <view class="progress-ring-progress {{learnProgress >= 50 ? 'half' : ''}}" style="transform: rotate({{learnProgress * 3.6}}deg)"></view>
            <view class="progress-ring-center">
              <text class="progress-ring-percent">{{learnProgress}}%</text>
              <text class="progress-ring-label">总进度</text>
            </view>
          </view>
        </view>
      </view>
      <!-- Word Count Footer in Card -->
      <view class="progress-card-footer">
        <text class="footer-quote">学而不思则罔，思而不学则殆</text>
        <text class="footer-remaining">还剩 {{totalCount - learnedCount}} 词</text>
      </view>
    </section>
    <!-- END: ProgressCard -->

    <!-- BEGIN: SessionInfo -->
    <section class="session-info">
      <text class="session-tip">每组 5 个词 · 先展示后练习</text>
    </section>
    <!-- END: SessionInfo -->

    <!-- BEGIN: ActionButtons -->
    <nav class="action-buttons">
      <!-- Start Button: Solid Scholarly Red -->
      <button class="action-btn start-btn" bindtap="startLearn">
        <text class="action-btn-text">开始学习</text>
      </button>
      <!-- Review Button: Outlined Scholarly Style -->
      <button class="action-btn review-btn" bindtap="startReview">
        <text class="action-btn-text">温故复习{{reviewCount > 0 ? '(' + reviewCount + ')' : ''}}</text>
      </button>
    </nav>
    <!-- END: ActionButtons -->

    <!-- 字音跟读入口 -->
    <view class="pronounce-entry" bindtap="goPronounce">
      <text class="pronounce-entry-icon">🔊</text>
      <text class="pronounce-entry-text">字音跟读 · 150字正音</text>
      <text class="pronounce-entry-arrow">›</text>
    </view>
  </main>
  <!-- END: ContentArea -->

  <!-- 学习中 -->
  <view wx:else>
    <!-- 退出按钮 -->
    <view class="exit-btn" style="top: calc(20rpx + {{statusBarHeight}}px)" bindtap="exitLearn">
      <text class="exit-btn-text">✕ 退出</text>
    </view>

    <!-- 展示环节 -->
    <view wx:if="{{phase === 'intro'}}" class="intro-phase">
      <view class="phase-title">先看看这组词的意思</view>
      <view class="group-progress">已学 {{learnedCount}}/{{totalCount}}</view>

      <!-- 当前展示的词 -->
      <view class="intro-word-item" wx:if="{{groupWords[introIndex]}}">
        <text class="intro-word">{{groupWords[introIndex].word}}</text>
        <view class="intro-meanings-list">
          <block wx:for="{{groupWords[introIndex].meanings}}" wx:for-item="m" wx:key="index">
            <view class="intro-meaning-item">
              <text class="meaning-number">{{index + 1}}.</text>
              <text class="meaning-text">{{m.meaning}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- 导航按钮 -->
      <view class="intro-btns">
        <button class="btn-prev" bindtap="prevIntro" wx:if="{{introIndex > 0}}">上一个</button>
        <button class="btn-next" bindtap="nextIntro" wx:if="{{introIndex < 4}}">下一个</button>
      </view>

      <button class="start-btn" bindtap="startPractice" wx:if="{{introIndex === 4}}">开始练习</button>
    </view>

    <!-- 练习环节 -->
    <view wx:if="{{phase === 'practice'}}" class="practice-phase">
      <!-- 顶部进度条 -->
      <view class="header-progress-bar" style="top: {{statusBarHeight}}px">
        <view class="header-progress-bg">
          <view class="header-progress-fill" style="width: {{(currentWordIndex * 5 + practiceCount) / 25 * 100}}%"></view>
        </view>
      </view>

      <!-- 头部信息 -->
      <view class="header-info">
        <view class="progress-info">
          <text class="page-title">文言文学习</text>
          <text class="progress-label">词进度</text>
          <text class="progress-text">{{currentWordIndex + 1}}/5 · 第 {{practiceCount + 1}}次</text>
        </view>
        <view class="group-info">
          <text class="group-label">已学 {{learnedCount}}/{{totalCount}}</text>
        </view>
      </view>

      <!-- 题目卡片 -->
      <view class="quiz-area">
        <!-- 语境选意思 -->
        <view wx:if="{{quizType === 'context'}}" class="main-card">
          <view class="quote-text">
            <text wx:for="{{quiz.sentenceParts}}" wx:key="index" wx:for-item="part" class="{{part.isBold ? 'bold-word' : ''}}">{{part.text}}</text>
          </view>
        </view>

        <!-- 根据意思选句子 -->
        <view wx:if="{{quizType === 'sentence'}}" class="main-card">
          <view class="quote-text">"{{quiz.word}}" - "{{quiz.meaning}}"</view>
        </view>

        <!-- 问题 -->
        <view class="question-text">
          <text wx:if="{{quizType === 'context'}}">句中加粗字的意思？</text>
          <text wx:if="{{quizType === 'sentence'}}">选择正确的句子</text>
        </view>

        <!-- 选项 -->
        <view class="options-area">
          <block wx:for="{{optionDisplays}}" wx:key="index">
            <view class="option-btn {{selectedIndex === index ? (index === quiz.correctIndex ? 'correct' : 'wrong') : ''}}"
                  bindtap="selectAnswer" data-index="{{index}}">
              <text>{{item.text}}</text>
            </view>
          </block>
        </view>

        <!-- 看答案 -->
        <view class="answer-btn-area" wx:if="{{!showResult}}">
          <button class="answer-btn" bindtap="giveUp">看答案</button>
        </view>

        <!-- 结果 -->
        <view wx:if="{{showResult}}" class="result-area">
          <text wx:if="{{isCorrect}}" class="result-correct">✓ 回答正确！</text>
          <text wx:else class="result-wrong">✗ 正确答案是：{{quiz.correctAnswer}}</text>
        </view>

        <!-- 下一题 -->
        <view wx:if="{{showResult}}" class="next-btn-area">
          <button class="next-btn" bindtap="nextQuestion">下一题</button>
        </view>
      </view>

      <!-- 底部标熟 -->
      <view class="mark-known-area">
        <button class="mark-known-btn" bindtap="markKnown">标熟</button>
      </view>
    </view>

    <!-- 复习阶段 -->
    <view wx:if="{{phase === 'review'}}" class="review-phase">
      <view class="review-header">
        <text class="review-title">复习</text>
        <button class="btn-back" bindtap="goHome">返回</button>
      </view>
      <view class="review-tip">今日待复习: {{reviewWords.length}} 个</view>
      <scroll-view scroll-y class="review-list" wx:if="{{reviewWords.length > 0}}">
        <block wx:for="{{reviewWords}}" wx:key="word">
          <view class="review-item">
            <text class="review-word">{{item.word}}</text>
            <view class="review-btns">
              <button size="mini" class="btn-know" bindtap="markReviewKnown" data-word="{{item.word}}">认识</button>
              <button size="mini" class="btn-forget" bindtap="markReviewForget" data-word="{{item.word}}">不认识</button>
            </view>
          </view>
        </block>
      </scroll-view>
      <view wx:if="{{reviewWords.length === 0}}" class="no-review">🎉 今日复习完成！</view>
    </view>
  </view>
</view>