/* pages/learn/learn.wxss */

/* 字体设置 - EB Garamond */
page {
  font-family: 'EB Garamond', Georgia, 'Times New Roman', serif;
}

.container {
  min-height: 100vh;
  height: 100vh;
  background: linear-gradient(135deg, #fcf9f8 0%, #f7f3f0 100%);
  padding: 48rpx;
  font-family: 'EB Garamond', Georgia, 'Times New Roman', serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 统一原生 button 默认样式：去掉默认描边/背景，避免按钮大小粗细不一致 */
button {
  margin: 0;
  padding: 0;
  line-height: 1.4;
  font-size: inherit;
  font-weight: inherit;
  background: transparent;
  border-radius: 0;
  box-sizing: border-box;
}
button::after {
  border: none;
}

.header-title,
.progress-card-title,
.progress-ring-percent,
.action-btn-text {
  font-family: 'EB Garamond', Georgia, 'Times New Roman', serif;
}

/* BEGIN: MainHeader */
.main-header {
  width: 100%;
  margin-top: 32rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.header-title {
  font-size: 60rpx;
  font-weight: bold;
  color: #bc262e;
  letter-spacing: 8rpx;
  border-bottom: 4rpx solid rgba(188, 38, 46, 0.2);
  padding-bottom: 24rpx;
  display: inline-block;
}
/* END: MainHeader */

/* BEGIN: ContentArea */
.content-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}
/* END: ContentArea */

/* BEGIN: ProgressCard */
.progress-card {
  background: linear-gradient(135deg, #fcf9f8 0%, #f7f3f0 100%);
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx -2px rgba(0, 0, 0, 0.05), 0 2rpx 10rpx -2px rgba(0, 0, 0, 0.03);
  border: 1rpx solid #dcd9d9;
  position: relative;
  overflow: hidden;
}

.progress-card-inner {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.progress-card-left {
  flex: 1;
}

.progress-card-status-area {
  margin-bottom: 16rpx;
}

.progress-card-status {
  font-size: 20rpx;
  color: #6b7280;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.progress-card-title-area {
  margin-bottom: 16rpx;
}

.progress-card-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2d2d2d;
}

.progress-card-info-area {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-card-current,
.progress-card-chapter {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
}

.divider {
  margin: 0 16rpx;
  color: #d1d5db;
}

.current-word,
.chapter-count {
  color: #2d2d2d;
  font-weight: 500;
}

/* Progress Indicator */
.progress-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.progress-card-right .progress-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #bc262e;
}

.progress-card-right .progress-label {
  font-size: 24rpx;
  color: #999;
}

.progress-ring-container {
  position: relative;
  width: 192rpx;
  height: 192rpx;
  border-radius: 96rpx;
  background: #dcd9d9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-ring-bg {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, #fcf9f8 0%, #f7f3f0 100%);
}

.progress-ring-progress {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 10rpx solid transparent;
  border-top-color: #bc262e;
  border-right-color: #bc262e;
  box-sizing: border-box;
  transition: transform 0.5s ease-out;
}

.progress-ring-progress.half {
  border-bottom-color: #bc262e;
  border-left-color: #bc262e;
}

.progress-ring-center {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.progress-ring-percent {
  font-size: 48rpx;
  font-weight: bold;
  color: #2d2d2d;
}

.progress-ring-label {
  font-size: 18rpx;
  color: #6b7280;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-top: 4rpx;
}

/* Word Count Footer in Card */
.progress-card-footer {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #d1d5db;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-quote {
  font-size: 22rpx;
  color: #6b7280;
  font-style: italic;
}

.footer-remaining {
  font-size: 22rpx;
  font-weight: 600;
  color: #bc262e;
}
/* END: ProgressCard */

/* BEGIN: SessionInfo */
.session-info {
  text-align: center;
  padding: 16rpx 0;
}

.session-tip {
  font-size: 26rpx;
  color: #6b7280;
  font-style: italic;
}
/* END: SessionInfo */

/* BEGIN: ActionButtons */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  align-items: stretch;
}

/* 两个按钮共用尺寸，保证宽高完全一致（用 .action-buttons 前缀提高优先级，盖过下方旧的 .start-btn{width:50%}） */
.action-buttons .action-btn {
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx -2px rgba(0, 0, 0, 0.05), 0 2rpx 10rpx -2px rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}

/* Start Button: Solid Scholarly Red */
.action-btn.start-btn {
  background: linear-gradient(135deg, #bc262e 0%, #8a1a1f 100%);
  color: #fff;
  border: 2rpx solid transparent;
}

.action-btn.start-btn:active {
  transform: scale(0.95);
}

/* Review Button: Outlined Scholarly Style */
.action-btn.review-btn {
  background: #fff;
  border: 2rpx solid rgba(188, 38, 46, 0.3);
  color: #bc262e;
}

.action-btn.review-btn:active {
  border-color: #bc262e;
  transform: scale(0.95);
}

.action-btn-text {
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 6rpx;
  white-space: nowrap;
}
/* END: ActionButtons */

/* 字音跟读入口 */
.pronounce-entry {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid rgba(188, 38, 46, 0.18);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.pronounce-entry:active {
  background: #faf5f4;
}
.pronounce-entry-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.pronounce-entry-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1b1c1c;
  letter-spacing: 2rpx;
}
.pronounce-entry-arrow {
  font-size: 40rpx;
  color: #bc262e;
}

/* 以下是原有样式保留 */

.progress-card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.progress-card-info {
  flex: 1;
}

.progress-card-status {
  font-size: 24rpx;
  color: #717971;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.progress-card-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1b1c1c;
  display: block;
  margin-bottom: 8rpx;
}

.progress-card-current {
  font-size: 28rpx;
  color: #414942;
  display: block;
}

.progress-card-ring {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.progress-ring-outer {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #e4e2e1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-ring-bg {
  position: absolute;
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background: #f0ebe3;
}

.progress-ring-progress {
  position: absolute;
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  border: 8rpx solid transparent;
  border-top-color: #bc262e;
  border-right-color: #bc262e;
  box-sizing: border-box;
  transition: transform 0.5s ease-out;
}

.progress-ring-progress.half {
  border-bottom-color: #bc262e;
  border-left-color: #bc262e;
}

.progress-ring-center {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-ring-percent {
  font-size: 32rpx;
  font-weight: 500;
  color: #bc262e;
}

.progress-card-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid rgba(193, 201, 191, 0.5);
}

.progress-card-chapter {
  font-size: 24rpx;
  color: #717971;
}

.progress-card-remaining {
  font-size: 24rpx;
  color: #717971;
}

.start-card {
  text-align: center;
  padding: 48rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(185, 28, 28, 0.1);
}

.start-card-btns {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 32rpx;
}

.start-card-btns .start-btn {
  margin-top: 0;
  width: auto;
  flex: 1;
}

.start-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #bc262e;
  margin-bottom: 30rpx;
}

.start-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.start-btn {
  margin-top: 32rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #bc262e 0%, #8a1a1f 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: none;
  width: 50%;
  box-shadow: 0 4rpx 16rpx rgba(171, 51, 52, 0.25);
  transition: all 0.3s ease;
}

.start-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 10rpx rgba(185, 28, 28, 0.2);
}

/* 进度条 */
.progress-bar-container {
  width: 80%;
  margin: 30rpx auto;
  text-align: center;
}

.progress-bar {
  height: 16rpx;
  background: #f0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #bc262e, #e53935);
  border-radius: 8rpx;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(185, 28, 28, 0.3);
}

.progress-text {
  font-size: 24rpx;
  color: #bc262e;
  font-weight: bold;
}

/* 展示环节 */
.intro-phase {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  min-height: 80vh;
  justify-content: space-between;
}

.phase-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.group-progress {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.word-list {
  width: 100%;
  max-height: 55vh;
}

.intro-word-item {
  padding: 40rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.intro-word {
  font-size: 96rpx;
  font-weight: bold;
  color: #bc262e;
  display: block;
  margin-bottom: 40rpx;
  text-align: center;
  letter-spacing: 8rpx;
}

.intro-meanings {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.intro-meanings-list {
  width: 100%;
}

.intro-meaning-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border-left: 8rpx solid #bc262e;
}

.meaning-number {
  font-size: 28rpx;
  color: #bc262e;
  font-weight: bold;
  margin-right: 16rpx;
  min-width: 40rpx;
}

.meaning-text {
  font-size: 34rpx;
  color: #333;
  line-height: 1.7;
}

.intro-meaning {
  font-size: 32rpx;
  color: #333;
  background: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  margin: 8rpx;
}

/* 展示导航按钮 */
.intro-btns {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-prev, .btn-next {
  padding: 20rpx 40rpx;
  background: #fff;
  color: #333;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 2rpx solid #ddd;
  transition: all 0.15s ease;
}

.btn-prev:active, .btn-next:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.btn-next {
  background: #bc262e;
  color: #fff;
  border: none;
}

/* 练习环节 */
.practice-phase {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
  padding-bottom: 20rpx;
}

.practice-phase .header-progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  z-index: 100;
}

.header-progress-bg {
  height: 4rpx;
  background: #e4e2e1;
  width: 100%;
}

.header-progress-fill {
  height: 4rpx;
  background: #bc262e;
  transition: width 0.3s ease;
}

.header-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  width: 100%;
  padding: 80rpx 0 24rpx;
}

.progress-info {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-family: 'EB Garamond', serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #414942;
}

.progress-label {
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: #717971;
  font-weight: 500;
}

.progress-text {
  font-family: 'EB Garamond', serif;
  font-size: 36rpx;
  font-weight: 500;
  color: #1b1c1c;
}

.group-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.group-label {
  font-size: 20rpx;
  color: #717971;
}

.quiz-area {
  width: 100%;
  flex-shrink: 0;
}

.main-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid rgba(193, 201, 191, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 16rpx;
}

.quote-text {
  font-family: 'EB Garamond', serif;
  font-size: 40rpx;
  color: #1b1c1c;
  line-height: 1.8;
}

.quote-source {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}

.question-text {
  text-align: center;
  font-family: 'EB Garamond', serif;
  font-size: 28rpx;
  color: #1b1c1c;
  padding: 12rpx 0 16rpx;
}

.bold-word {
  font-weight: bold;
  color: #bc262e;
}

.options-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.option-btn {
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  text-align: center;
  border: 1rpx solid rgba(193, 201, 191, 0.4);
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-btn:active {
  background: #f0eded;
}

.option-btn.correct {
  background: #E8F5E9 !important;
  border-color: #4CAF50 !important;
  color: #4CAF50 !important;
}

.option-btn.wrong {
  background: #FFEBEE !important;
  border-color: #F44336 !important;
  color: #F44336 !important;
}

.option-btn.selected {
  background: #E3F2FD !important;
  border-color: #1976D2 !important;
  color: #1976D2 !important;
}

@keyframes correctPulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

@keyframes wrongShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-5rpx); }
  75% { transform: translateX(5rpx); }
}

/* 结果 */
.result-area {
  text-align: center;
  padding: 32rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}

.result-correct {
  color: #316342;
  display: block;
}

.result-wrong {
  color: #bc262e;
  display: block;
}

/* 看答案按钮 */
.answer-btn-area {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.answer-btn {
  font-family: 'EB Garamond', serif;
  font-size: 32rpx;
  font-weight: 600;
  color: #bc262e;
  background: #fff;
  border: 2rpx solid #bc262e;
  border-radius: 24rpx;
  padding: 24rpx 56rpx;
}

/* 下一题按钮 */
.next-btn-area {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.next-btn {
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 56rpx;
  background: #bc262e;
  color: #fff;
  border-radius: 24rpx;
}

/* 结果页面左右按钮 */
.result-btns {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FDFBF7;
  z-index: 100;
}

.result-btns .answer-btn {
  flex: 1;
  background: #f5f5f5;
  color: #666;
}

.result-btns .next-btn {
  flex: 1;
  background: #bc262e;
  color: #fff;
}

.result-btns .next-btn.disabled {
  flex: 1;
  background: #ccc;
  color: #888;
}

.result-btns .next-btn:only-child {
  margin: 0 auto;
}

.action-btns .btn.next {
  padding: 20rpx 60rpx;
  background: #bc262e;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-give-up {
  padding: 20rpx 40rpx;
  background: #FF9800;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

/* 统计 */
.stats {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  width: 90%;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #bc262e;
  text-shadow: 0 2rpx 8rpx rgba(185, 28, 28, 0.2);
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 复习阶段 */
.review-phase {
  padding: 20rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.review-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.btn-back {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
}

.exit-btn {
  position: fixed;
  top: 20rpx;
  left: 20rpx;
  z-index: 100;
  padding: 12rpx 24rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 30rpx;
}

.exit-btn-text {
  font-size: 26rpx;
  color: #666;
}

.review-tip {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.review-list {
  max-height: 60vh;
  padding: 10rpx;
}

.review-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
