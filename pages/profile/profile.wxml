<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <!-- 未登录 -->
    <view wx:if="{{!loggedIn}}" class="avatar-section" bindtap="handleLogin">
      <view class="avatar">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-info">
        <text class="username">点击登录</text>
      </view>
    </view>

    <!-- 已登录 -->
    <view wx:else class="avatar-section">
      <view class="avatar">
        <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill"/>
        <text wx:else class="avatar-text">👤</text>
      </view>
      <view class="user-info">
        <text class="username">{{userInfo.nickname || '文言学者'}}</text>
      </view>
      <button class="logout-btn" size="mini" bindtap="handleLogin">退出</button>
    </view>

    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-number">{{stats.words}}</text>
        <text class="stat-label">查词数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.collections}}</text>
        <text class="stat-label">收藏数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.translations}}</text>
        <text class="stat-label">翻译数</text>
      </view>
    </view>
  </view>

  <!-- 云端同步（登录后显示） -->
  <view wx:if="{{loggedIn}}" class="sync-section">
    <button class="sync-btn" bindtap="syncData">上传到云端</button>
    <button class="sync-btn download-btn" bindtap="downloadData">下载云端</button>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <!-- 学习记录 -->
    <view class="menu-item" bindtap="viewHistory">
      <view class="menu-left">
        <text class="menu-text">学习记录</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 我的收藏 -->
    <view class="menu-item" bindtap="viewCollections">
      <view class="menu-left">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{stats.collections}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 翻译历史 -->
    <view class="menu-item" bindtap="viewTranslations">
      <view class="menu-left">
        <text class="menu-icon">📝</text>
        <text class="menu-text">翻译历史</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{stats.translations}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="viewAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">古字通 v1.0.0</text>
  </view>
</view>