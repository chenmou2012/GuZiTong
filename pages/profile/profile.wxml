<view class="container" style="padding-top: calc(20rpx + {{statusBarHeight}}px)">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <!-- 未登录 -->
    <view wx:if="{{!loggedIn}}" class="avatar-section" bindtap="handleLogin">
      <view class="avatar">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-info">
        <text class="username">点击登录</text>
      </view>
    </view>

    <!-- 已登录 -->
    <view wx:else class="avatar-section">
      <view class="avatar">
        <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill"/>
        <text wx:else class="avatar-text">👤</text>
      </view>
      <view class="user-info">
        <text class="username">{{userInfo.nickname || '文言学者'}}</text>
      </view>
      <button class="logout-btn" size="mini" bindtap="handleLogin">退出</button>
    </view>

    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-number">{{stats.words}}</text>
        <text class="stat-label">查词数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.collections}}</text>
        <text class="stat-label">收藏数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.translations}}</text>
        <text class="stat-label">翻译数</text>
      </view>
    </view>
  </view>

  <!-- 学习统计卡片 -->
  <view class="stats-card">
    <view class="stats-card-header">
      <text class="stats-card-title">学习统计</text>
    </view>
    <view class="stats-card-content">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.todayLearn}}</text>
          <text class="stats-item-label">今日学习</text>
        </view>
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.todayReview}}</text>
          <text class="stats-item-label">今日复习</text>
        </view>
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.streakDays}}</text>
          <text class="stats-item-label">连续学习（天）</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 学习进度饼图 -->
  <view class="chart-card">
    <view class="chart-header">
      <text class="chart-title">学习进度</text>
    </view>
    <view class="chart-content">
      <view class="pie-circle" style="background: conic-gradient(#d0d0d0 0deg {{pieChart.unlearnedPercent}}deg, #f5ad1e {{pieChart.unlearnedPercent}}deg {{pieChart.unlearnedPercent + pieChart.reviewingPercent}}deg, #4CAF50 {{pieChart.unlearnedPercent + pieChart.reviewingPercent}}deg 360deg);"></view>
      <view class="chart-legend">
        <view class="legend-item">
          <view class="legend-color" style="background:#d0d0d0"></view>
          <text>未学习 {{pieChart.unlearned}}</text>
        </view>
        <view class="legend-item">
          <view class="legend-color" style="background:#f5ad1e"></view>
          <text>复习中 {{pieChart.reviewing}}</text>
        </view>
        <view class="legend-item">
          <view class="legend-color" style="background:#4CAF50"></view>
          <text>复习完成 {{pieChart.reviewed}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <!-- 学习设置 -->
    <view class="menu-item" bindtap="showSettings">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">学习设置</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 学习记录 -->
    <view class="menu-item" bindtap="viewHistory">
      <view class="menu-left">
        <text class="menu-text">学习记录</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 我的收藏 -->
    <view class="menu-item" bindtap="viewCollections">
      <view class="menu-left">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{stats.collections}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 翻译历史 -->
    <view class="menu-item" bindtap="viewTranslations">
      <view class="menu-left">
        <text class="menu-icon">📝</text>
        <text class="menu-text">翻译历史</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{stats.translations}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="viewAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">古字通 v1.0.0</text>
  </view>

  <!-- 设置弹窗 -->
  <view class="settings-modal" wx:if="{{showSettingsModal}}">
    <view class="settings-overlay" bindtap="hideSettings"></view>
    <view class="settings-content">
      <view class="settings-header">
        <text class="settings-title">学习设置</text>
        <text class="settings-close" bindtap="hideSettings">×</text>
      </view>
      <view class="settings-body">
        <view class="settings-item">
          <text class="settings-label">每组字数</text>
          <view class="settings-options">
            <text class="settings-option {{settings.groupSize === 3 ? 'active' : ''}}" bindtap="changeGroupSize" data-size="3">3</text>
            <text class="settings-option {{settings.groupSize === 5 ? 'active' : ''}}" bindtap="changeGroupSize" data-size="5">5</text>
            <text class="settings-option {{settings.groupSize === 10 ? 'active' : ''}}" bindtap="changeGroupSize" data-size="10">10</text>
          </view>
        </view>
        <view class="settings-item">
          <text class="settings-label">同步</text>
          <button class="settings-sync-btn" bindtap="syncData" wx:if="{{loggedIn}}">同步数据</button>
          <text class="settings-tip" wx:else>登录后可用</text>
        </view>
      </view>
    </view>
  </view>
</view>