<view class="container" style="padding-top: calc(20rpx + {{statusBarHeight}}px)">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <!-- 未登录 -->
    <view wx:if="{{!loggedIn}}" class="avatar-section" bindtap="handleLogin">
      <view class="avatar">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-info">
        <text class="username">点击登录</text>
      </view>
    </view>

    <!-- 已登录 -->
    <view wx:else class="avatar-section">
      <view class="avatar">
        <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill"/>
        <text wx:else class="avatar-text">👤</text>
      </view>
      <view class="user-info">
        <text class="username">{{userInfo.nickname || '文言学者'}}</text>
      </view>
      <button class="logout-btn" size="mini" bindtap="handleLogin">退出</button>
    </view>

    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-number">{{stats.words}}</text>
        <text class="stat-label">查词数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.collections}}</text>
        <text class="stat-label">收藏数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.translations}}</text>
        <text class="stat-label">翻译数</text>
      </view>
    </view>
  </view>

  <!-- 云端同步（登录后显示） -->
  <view wx:if="{{loggedIn}}" class="sync-section">
    <button class="sync-btn" bindtap="syncData">上传到云端</button>
    <button class="sync-btn download-btn" bindtap="downloadData">下载云端</button>
  </view>

  <!-- 学习统计卡片 -->
  <view class="stats-card">
    <view class="stats-card-header">
      <text class="stats-card-title">学习统计</text>
    </view>
    <view class="stats-card-content">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.todayReview}}</text>
          <text class="stats-item-label">今日复习</text>
        </view>
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.todayDone}}</text>
          <text class="stats-item-label">已完成</text>
        </view>
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.streakDays}}</text>
          <text class="stats-item-label">连续学习</text>
        </view>
      </view>
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-item-number">{{reviewStats.totalCorrect > 0 ? Math.round(reviewStats.totalCorrect / (reviewStats.totalCorrect + reviewStats.totalWrong) * 100) : 0}}%</text>
          <text class="stats-item-label">正确率</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 艾宾浩斯进度 -->
  <view class="ebbinghaus-card">
    <view class="ebbinghaus-header">
      <text class="ebbinghaus-title">艾宾浩斯记忆曲线</text>
    </view>
    <view class="ebbinghaus-content">
      <view class="ebbinghaus-stage">
        <text class="stage-label">阶段1 (1天)</text>
        <view class="stage-bar">
          <view class="stage-fill" style="width: {{reviewStats.stageCounts[1] / 33 * 100}}%"></view>
        </view>
        <text class="stage-count">{{reviewStats.stageCounts[1]}}</text>
      </view>
      <view class="ebbinghaus-stage">
        <text class="stage-label">阶段2 (3天)</text>
        <view class="stage-bar">
          <view class="stage-fill" style="width: {{reviewStats.stageCounts[2] / 33 * 100}}%"></view>
        </view>
        <text class="stage-count">{{reviewStats.stageCounts[2]}}</text>
      </view>
      <view class="ebbinghaus-stage">
        <text class="stage-label">阶段3 (7天)</text>
        <view class="stage-bar">
          <view class="stage-fill" style="width: {{reviewStats.stageCounts[3] / 33 * 100}}%"></view>
        </view>
        <text class="stage-count">{{reviewStats.stageCounts[3]}}</text>
      </view>
      <view class="ebbinghaus-stage">
        <text class="stage-label">阶段4 (15天)</text>
        <view class="stage-bar">
          <view class="stage-fill" style="width: {{reviewStats.stageCounts[4] / 33 * 100}}%"></view>
        </view>
        <text class="stage-count">{{reviewStats.stageCounts[4]}}</text>
      </view>
      <view class="ebbinghaus-stage">
        <text class="stage-label">阶段5 (30天)</text>
        <view class="stage-bar">
          <view class="stage-fill" style="width: {{reviewStats.stageCounts[5] / 33 * 100}}%"></view>
        </view>
        <text class="stage-count">{{reviewStats.stageCounts[5]}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <!-- 学习记录 -->
    <view class="menu-item" bindtap="viewHistory">
      <view class="menu-left">
        <text class="menu-text">学习记录</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 我的收藏 -->
    <view class="menu-item" bindtap="viewCollections">
      <view class="menu-left">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{stats.collections}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 翻译历史 -->
    <view class="menu-item" bindtap="viewTranslations">
      <view class="menu-left">
        <text class="menu-icon">📝</text>
        <text class="menu-text">翻译历史</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{stats.translations}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="viewAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">古字通 v1.0.0</text>
  </view>
</view>