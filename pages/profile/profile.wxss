/* 页面整体样式 */
.container {
  min-height: 100vh;
  background-color: #FDFBF7;
  padding: 20rpx 30rpx 120rpx;
  box-sizing: border-box;
}

/* 用户信息头部 */
.profile-header {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #B91C1C, #991b1b);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 36rpx;
  color: #2C3E50;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: #B91C1C;
  padding: 4rpx 16rpx;
  background-color: #fef2f2;
  border-radius: 20rpx;
  width: fit-content;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.logout-btn {
  margin-top: 10rpx;
  background: #f5f5f5 !important;
  color: #666 !important;
  font-size: 24rpx;
}

/* 同步区域 */
.sync-section {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.sync-btn {
  padding: 16rpx 40rpx;
  background: #B91C1C;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.download-btn {
  background: #4CAF50;
}

/* 统计数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  color: #2C3E50;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

/* 功能列表 */
.menu-section {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #fafafa;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #2C3E50;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-count {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 版本信息 */
.version-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: #ddd;
}
