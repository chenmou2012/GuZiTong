/* 页面整体样式 */
.container {
  min-height: 100vh;
  background-color: #FDFBF7;
  padding: 20rpx 30rpx 120rpx;
  box-sizing: border-box;
}

/* 用户信息头部 */
.profile-header {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #B91C1C, #991b1b);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 36rpx;
  color: #2C3E50;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: #B91C1C;
  padding: 4rpx 16rpx;
  background-color: #fef2f2;
  border-radius: 20rpx;
  width: fit-content;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.logout-btn {
  margin-top: 10rpx;
  background: #f5f5f5 !important;
  color: #666 !important;
  font-size: 24rpx;
}

/* 同步区域 */
.sync-section {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.sync-btn {
  padding: 16rpx 40rpx;
  background: #B91C1C;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.download-btn {
  background: #4CAF50;
}

/* 统计数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  color: #2C3E50;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

/* 功能列表 */
.menu-section {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #fafafa;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #2C3E50;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-count {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 版本信息 */
.version-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

/* 设置弹窗 */
.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.settings-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.settings-content {
  position: relative;
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.settings-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.settings-close {
  font-size: 48rpx;
  color: #999;
}

.settings-body {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.settings-label {
  font-size: 30rpx;
  color: #333;
}

.settings-options {
  display: flex;
  gap: 16rpx;
}

.settings-option {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
}

.settings-option.active {
  background: #1aad19;
  color: #fff;
}

.settings-sync-btn {
  background: #1aad19;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.settings-tip {
  font-size: 28rpx;
  color: #999;
}

.version-text {
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: #ddd;
}

/* 学习统计卡片 */
.stats-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stats-card-header {
  margin-bottom: 20rpx;
}

.stats-card-title {
  font-size: 32rpx;
  color: #2C3E50;
  font-weight: bold;
}

.stats-card-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-item-number {
  font-size: 40rpx;
  color: #bc262e;
  font-weight: bold;
}

.stats-item-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

/* 艾宾浩斯进度卡片 */
.ebbinghaus-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.ebbinghaus-header {
  margin-bottom: 20rpx;
}

.ebbinghaus-title {
  font-size: 32rpx;
  color: #2C3E50;
  font-weight: bold;
}

.ebbinghaus-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ebbinghaus-stage {
  display: flex;
  align-items: center;
}

.stage-label {
  font-size: 24rpx;
  color: #666;
  width: 160rpx;
}

.stage-bar {
  flex: 1;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.stage-fill {
  height: 100%;
  background: linear-gradient(90deg, #bc262e, #e53935);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.stage-count {
  font-size: 24rpx;
  color: #bc262e;
  font-weight: bold;
  width: 40rpx;
  text-align: right;
}

/* 饼图样式 */
.chart-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.chart-header {
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 32rpx;
  color: #2C3E50;
  font-weight: bold;
}

.chart-content {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.pie-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #eee;
}

.chart-legend {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}
