/* pages/review/review.wxss */
.container {
  min-height: 100vh;
  background-color: #FDFBF7;
}

.review-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #bc262e;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 48rpx;
}

.quiz-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.main-card {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 64rpx 32rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
  align-items: center;
}

.word {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
}

.meaning-area {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.meaning-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meaning-item {
  display: flex;
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
}

.meaning-number {
  color: #bc262e;
  font-weight: bold;
  margin-right: 8rpx;
}

.meaning-text {
  flex: 1;
}

.btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  padding: 24rpx 32rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FDFBF7;
  z-index: 100;
}

.btn-known,
.btn-unknown,
.btn-next {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-known {
  background: #bc262e;
  color: #fff;
}

.btn-unknown {
  background: #f5f5f5;
  color: #666;
}

.btn-next {
  background: #bc262e;
  color: #fff;
}

/* 复习完成 */
.done-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  min-height: 60vh;
}

.done-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #bc262e;
  margin-bottom: 16rpx;
}

.done-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 64rpx;
}

.btn-home {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #bc262e;
  color: #fff;
  border: none;
}