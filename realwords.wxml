<!-- realwords.wxml -->
<view class="container" style="padding-top: calc(48rpx + {{statusBarHeight}}px)">
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text class="back-text">返回</text>
  </view>

  <!-- 标题 -->
  <view class="header">
    <text class="title">实词</text>
    <text class="subtitle">共 {{realWords.length}} 个</text>
  </view>

  
  <!-- 实词网格 -->
  <view class="word-grid">
    <view
      class="word-item"
      wx:for="{{filteredWords}}"
      wx:key="index"
      bindtap="onWordTap"
      data-word="{{item}}"
    >
      <text class="word-text">{{item}}</text>
    </view>
  </view>
</view>