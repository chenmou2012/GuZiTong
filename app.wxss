/**app.wxss**/
/* 全局样式 - 古字通 */

/* 页面基础样式 */
page {
  background-color: #FDFBF7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.6;
}

/* 全局容器 */
.container {
  min-height: 100vh;
  background-color: #FDFBF7;
  box-sizing: border-box;
}

/* Flex 布局工具类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 文字颜色 */
.text-primary {
  color: #2C3E50;
}

.text-accent {
  color: #B91C1C;
}

.text-secondary {
  color: #666;
}

.text-muted {
  color: #999;
}

/* 通用卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #B91C1C;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.btn-primary:active {
  background-color: #991b1b;
  transform: scale(0.98);
}

/* 底线样式 */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

/* 滚动区域 */
.scroll-view {
  flex: 1;
  overflow-y: auto;
}
